# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=churnwhisper

# Redis
REDIS_URL=redis://localhost:6379/0

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TEMPERATURE=0.3

# JWT Auth
JWT_SECRET_KEY=your-very-long-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App Configuration
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
MAX_ACCOUNTS_PER_USER=500
MAX_CONCURRENT_AI_CALLS=5
RECALC_TIMEOUT_SECONDS=600

# Scoring Thresholds
SCORE_CRITICAL_MAX=30
SCORE_ATTENTION_MAX=60

# Optional: Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@churnwhisper.com
